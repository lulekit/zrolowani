---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { buildMeta } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}
const { title, description, path } = Astro.props;
const meta = buildMeta({ title, description, path });
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={meta.canonical} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:image" content={meta.ogImage} />
    <Font cssVariable="--font-heading" preload />
    <Font cssVariable="--font-body" />
  </head>
  <body class="bg-brand-950 min-h-screen font-sans text-white antialiased">
    <slot />
  </body>
</html>
