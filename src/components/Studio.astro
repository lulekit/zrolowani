---
import SectionLabel from './SectionLabel.astro';
---

<section class="bg-paper-lav text-ink px-4 py-16">
  <div class="mx-auto max-w-3xl text-center">
    <SectionLabel text="O nas" />
    <p class="text-ink-soft mx-auto mt-4 max-w-2xl leading-relaxed">
      Gra „Zrolowani" powstała we współpracy firmy <strong class="text-ink">Netictech S.A.</strong>
      z pomysłodawcą <strong class="text-ink">Hubertem Glińskim</strong>. Netictech komercjalizuje
      innowacyjne pomysły i wspiera ich rozwój od koncepcji po wdrożenie.
    </p>
  </div>
</section>
