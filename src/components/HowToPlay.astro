---
import { Image } from 'astro:assets';
import SectionLabel from './SectionLabel.astro';
import s1 from '../assets/step-1.png';
import s2 from '../assets/step-2.png';
import s3 from '../assets/step-3.png';
import s4 from '../assets/step-4.png';
import s5 from '../assets/step-5.png';
import s6 from '../assets/step-6.png';

const steps = [
  {
    img: s1,
    ring: '#7b2cbf',
    text: 'Wybierz kolor tabliczek i dobierz ich liczbę do liczby graczy.',
  },
  { img: s2, ring: '#f4b43f', text: 'Podpisz każdą tabliczkę literą odpowiadającą graczowi.' },
  { img: s3, ring: '#ff5c7a', text: 'Rozłóż karty z rolami — tyle, ilu jest graczy.' },
  {
    img: s4,
    ring: '#33d17a',
    text: 'Przyporządkuj graczy do ról w tajnym głosowaniu tabliczkami.',
  },
  { img: s5, ring: '#35a7ff', text: 'Odkryjcie po kolei wyniki głosowania.' },
  { img: s6, ring: '#ff9f45', text: 'Zdobądź punkt, jeśli obstawiłeś jak większość.' },
];
---

<section id="zasady" class="bg-paper text-ink scroll-mt-20 px-4 py-16">
  <div class="mx-auto max-w-5xl">
    <SectionLabel text="Jak grać — w 6 krokach" />
    <ol class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        steps.map((step, i) => (
          <li class="flex flex-col items-center text-center">
            <div class="relative">
              <Image
                src={step.img}
                alt={`Krok ${i + 1}`}
                width={220}
                class="h-28 w-28 rounded-full object-cover"
              />
            </div>
            <div
              class="font-display text-ink mt-3 flex h-10 w-10 items-center justify-center rounded-full text-lg font-extrabold"
              style={`border:4px solid ${step.ring}`}
            >
              {i + 1}
            </div>
            <p class="text-ink-soft mt-3 text-sm">{step.text}</p>
          </li>
        ))
      }
    </ol>
    <div class="mt-10 text-center">
      <span
        class="border-ink/20 text-ink-soft inline-flex items-center gap-2 rounded-xl border px-4 py-2 text-sm"
      >
        ▶ Instrukcja wideo / PDF — wkrótce
      </span>
    </div>
  </div>
</section>
