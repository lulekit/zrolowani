---
import logo from '../assets/logo.png';
import slogan from '../assets/slogan.png';
import president from '../assets/char-president.png';
import superhero from '../assets/char-hero.png';
import astronaut from '../assets/char-astronaut.png';
import BuyButton from './BuyButton.astro';

// Logo i slogan to przezroczyste PNG-i (napisy). Serwujemy je jako oryginalne
// pliki (plain <img>), z pominięciem stratnej konwersji do webp przez <Image> —
// to eliminuje brzegowy artefakt skalowania (ciemna obwódka) i zachowuje cień logo.
//
// Postacie: 3 osobne warstwy odtwarzające oryginalną kompozycję (odniesienie
// 1234×625) — każda unosi się niezależnie (animate-floaty, różne opóźnienia).

const facts = ['2–6 graczy', '20–60 min', '14+'];
---

<section
  id="top"
  class="relative overflow-hidden bg-[radial-gradient(140%_100%_at_50%_-10%,#241046_0%,#0b0616_62%)] px-4 pt-28 pb-20 text-center"
>
  <canvas
    data-hero-stars
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 z-0 h-full w-full"></canvas>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute right-6 bottom-0 z-0 hidden aspect-[1234/625] w-[40%] max-w-xl lg:block xl:right-16"
  >
    <img
      src={president.src}
      alt=""
      class="animate-floaty absolute"
      style="left:0%;top:3.36%;width:29.9%;animation-delay:0s"
    />
    <img
      src={superhero.src}
      alt=""
      class="animate-floaty absolute"
      style="left:34.85%;top:0%;width:31.12%;animation-delay:.7s"
    />
    <img
      src={astronaut.src}
      alt=""
      class="animate-floaty absolute"
      style="left:68.56%;top:3.68%;width:31.44%;animation-delay:1.4s"
    />
  </div>

  <div class="relative z-10 mx-auto max-w-3xl">
    <h1 class="sr-only">Zrolowani — imprezowa gra planszowa</h1>
    <img
      src={logo.src}
      width={logo.width}
      height={logo.height}
      alt="Zrolowani"
      class="mx-auto h-auto w-64 sm:w-80"
    />
    <img
      src={slogan.src}
      width={slogan.width}
      height={slogan.height}
      alt="Prezydent, superbohater, a może kosmonauta?"
      class="mx-auto mt-6 h-auto w-[36rem] max-w-full -rotate-3 sm:w-[52rem]"
    />
    <p class="mx-auto mt-6 max-w-md text-white/70">
      Imprezowa gra, w której dopasowujesz znajomych do zwariowanych ról.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <BuyButton />
      <a
        href="#zasady"
        class="font-display inline-flex items-center justify-center rounded-xl border border-white/25 px-5 py-3 font-semibold text-white transition hover:bg-white/10"
        >Jak grać</a
      >
    </div>
    <div class="mt-8 flex flex-wrap justify-center gap-x-4 gap-y-1 text-sm text-white/55">
      {
        facts.map((f, i) => (
          <>
            {i > 0 && <span class="opacity-40">•</span>}
            <span>{f}</span>
          </>
        ))
      }
    </div>
  </div>
</section>
