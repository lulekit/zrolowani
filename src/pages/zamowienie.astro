---
import Layout from '../layouts/Layout.astro';

// Formularz zamówienia (Faza 2 — M3/M4). Jeden produkt, stała cena, bez koszyka.
export const prerender = false;
---

<Layout title="Zamówienie" path="/zamowienie">
  <main class="mx-auto flex min-h-screen max-w-xl flex-col justify-center gap-4 px-6">
    <h1 class="text-3xl font-bold">Zamówienie</h1>
    <p class="text-white/70">
      Formularz zamówienia i płatność Przelewy24 — do implementacji (M3/M4).
    </p>
  </main>
</Layout>
