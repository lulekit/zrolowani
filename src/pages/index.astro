---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Features from '../components/Features.astro';
import HowToPlay from '../components/HowToPlay.astro';
import BoxContents from '../components/BoxContents.astro';
import Gallery from '../components/Gallery.astro';
import Studio from '../components/Studio.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <div data-reveal><About /></div>
    <div data-reveal><Features /></div>
    <HowToPlay />
    <div data-reveal><BoxContents /></div>
    <div data-reveal><Gallery /></div>
    <div data-reveal><Studio /></div>
    <FinalCta />
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/ui.ts';
</script>
