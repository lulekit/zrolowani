---
import Layout from '../layouts/Layout.astro';

// SZKIELET (M1). Pełna, dopracowana strona onepage powstanie w M2
// na bazie grafik i tekstów z katalogu docs/.
---

<Layout>
  <main
    class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center gap-6 px-6 text-center"
  >
    <p class="text-brand-400 text-sm tracking-widest uppercase">Netictech S.A.</p>
    <h1 class="text-5xl font-bold text-balance sm:text-6xl">Zrolowani</h1>
    <p class="text-brand-400 text-xl">Prezydent, superbohater, a&nbsp;może kosmonauta?</p>
    <p class="max-w-xl text-white/70">
      Imprezowa gra, w której dopasowujesz wszystkich graczy do zwariowanych ról. Szybka rozgrywka,
      humor i&nbsp;mnóstwo dyskusji.
    </p>
    <span
      class="border-brand-600 bg-brand-800/50 mt-4 rounded-full border px-5 py-2 text-sm text-white/60"
    >
      🚧 Szkielet projektu — pełna strona w przygotowaniu (M2)
    </span>
  </main>
</Layout>
